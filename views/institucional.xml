<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="institucional_tree" model="ir.ui.view">
        <field name="name">abatar.institucional.tree</field>
        <field name="model">abatar.institucional</field>
        <field name="arch" type="xml">
            <tree string="Lista de institucional">
                <field name="numero"/>
                <field name="relacion"/>
                <field name="active"/>
                <field name="resumen_busqueda" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="institucional_form" model="ir.ui.view">
        <field name="name">abatar.institucional.form</field>
        <field name="model">abatar.institucional</field>
        <field name="arch" type="xml">
            <form string="Form de productos">
                <sheet>
                    <header>
                    </header>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <span>Hola: </span>
                            <field name="numero" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="DATOS">
                            <field name="relacion"/>
                            <field name="fecha_creacion"/>
                            <field name="fecha_vencimiento"/>
                            <field name="user_id"/>
                        </group>
                        <group string="ADJUNTOS">
                            <field name="adjunto2"/>
                            <field name="adjunto1"/>

                        </group>
                        <group string="Comentarios">
                            <field name="desc"/>
                        </group>


                    </group>
                    <group>
                        <field name="admin" invisible="1"/>
                        <field name="resumen_busqueda" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="institucional_search" model="ir.ui.view">
        <field name="name">abatar.institucional.search.view</field>
        <field name="model">abatar.institucional</field>
        <field name="arch" type="xml">
            <search string="Buscar:">
                <field name="resumen_busqueda" />
                <separator/>

            </search>
        </field>
    </record>

    <record id="action_institucional" model="ir.actions.act_window">
            <field name="name">Institucional</field>
            <field name="res_model">abatar.institucional</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the first cash rounding</p>
            </field>
    </record>

    <record id="relacion_tree" model="ir.ui.view">
        <field name="name">abatar.relacion.institu.tree</field>
        <field name="model">abatar.relacion.institu</field>
        <field name="arch" type="xml">
            <tree string="Lista de productos">
                <field name="name"/>
                <field name="numero"/>
            </tree>
        </field>
    </record>

    <record id="relacion_form" model="ir.ui.view">
        <field name="name">abatar.relacion.institu.form</field>
        <field name="model">abatar.relacion.institu</field>
        <field name="arch" type="xml">
            <form string="Form de productos">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <field name="numero"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_relacion" model="ir.actions.act_window">
            <field name="name">Relacion Institucional</field>
            <field name="res_model">abatar.relacion.institu</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the first cash rounding</p>
            </field>
    </record>

    <record id="constantes_tree" model="ir.ui.view">
        <field name="name">abatar.constantes.tree</field>
        <field name="model">abatar.constantes</field>
        <field name="arch" type="xml">
            <tree string="Lista de Constantes">
                <field name="name"/>
                <field name="flotante"/>
                <field name="entero"/>
                <field name="char"/>
                <field name="booleano"/>
                <field name="fecha"/>
                <field name="fechatime"/>
                <field name="date_time"/>
                <field name="binario"/>
            </tree>
        </field>
    </record>

    <record id="constantes_form" model="ir.ui.view">
        <field name="name">abatar.constantes.form</field>
        <field name="model">abatar.constantes</field>
        <field name="arch" type="xml">
            <form string="Form de Constantes">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group>
                        <field name="flotante"/>
                        <field name="entero"/>
                        <field name="char"/>
                        <field name="booleano"/>
                        <field name="fecha"/>
                        <field name="fechatime"/>
                        <field name="date_time"/>
                        <field name="binario"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_constantes" model="ir.actions.act_window">
            <field name="name">Constantes Abatar</field>
            <field name="res_model">abatar.constantes</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the first Constant</p>
            </field>
    </record>


    <record id="abatar_mails_tree" model="ir.ui.view">
        <field name="name">abatar.mails.tree</field>
        <field name="model">abatar.mails</field>
        <field name="arch" type="xml">
            <tree string="Lista de Mails">
                <field name="mail_from"/>
                <field name="mail_to"/>
                <field name="fecha"/>
                <field name="asunto"/>
                <field name="texto"/>
            </tree>
        </field>
    </record>

    <record id="abatar_mails_form" model="ir.ui.view">
        <field name="name">abatar.mails.form</field>
        <field name="model">abatar.mails</field>
        <field name="arch" type="xml">
            <form string="Form de Mails">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="mail_from"/>
                        </h1>
                    </div>
                    <group>
                        <field name="mail_to"/>
                        <field name="fecha"/>
                        <field name="asunto"/>
                        <field name="texto"/>
                        <field name="adjuntos"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mails" model="ir.actions.act_window">
            <field name="name">Mails</field>
            <field name="res_model">abatar.mails</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Aquí veras los Mails recibidos y enviados</p>
            </field>
    </record>


</odoo>
