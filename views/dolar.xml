<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="dolar_tree" model="ir.ui.view">
        <field name="name">abatar.dolar.tree</field>
        <field name="model">abatar.dolar</field>
        <field name="arch" type="xml">
            <tree>
                <field name="fecha"/>
                <field name="pesos"/>
            </tree>
        </field>
    </record>

    <record id="dolar_form" model="ir.ui.view">
        <field name="name">abatar.dolar.form</field>
        <field name="model">abatar.dolar</field>
        <field name="arch" type="xml">
            <form string="Form de dolar">
                <group>
                    <field name="fecha"/>
                    <field name="pesos"/>
                </group>
            </form>
        </field>
    </record>

    <record id="board_graph_clientes" model="ir.ui.view">
        <field name="name">abatar.dolar.graph</field>
        <field name="model">abatar.dolar</field>
        <field name="arch" type="xml">
            <graph string="Dolar">
                <field name="fecha"/>
                <field name="pesos"/>
            </graph>
        </field>
    </record>

    <record id="action_dolar" model="ir.actions.act_window">
            <field name="name">dolar</field>
            <field name="res_model">abatar.dolar</field>
            <field name="limit">600</field>
            <field name="view_mode">tree,form,graph</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the first Dolar</p>
            </field>
    </record>




</odoo>
