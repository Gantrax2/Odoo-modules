<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="direcciones_tree" model="ir.ui.view">
        <field name="name">abatar.direcciones.tree</field>
        <field name="model">abatar.direcciones</field>
        <field name="arch" type="xml">
            <tree string="Lista de direcciones">
                <field name="cliente"/>
                <field name="cliente_gral" invisible="1" readonly="1"/>
                <field name="name_gral"/>
                <field name="localidad"/>
                <field name="provincia"/>
                <field name="forc_direc"/>
                <field name="restricciones"/>
                <field name="name" attrs="{'readonly': [('admin', '!=', True)]}"/>
                <field name="resumen_busqueda" invisible="1" />
                <field name="contacto" invisible="1"/>
                <field name="admin" invisible="1"/>
                <field name="sv_count" readonly="1"/>
            </tree>
        </field>
    </record>

    <record id="direcciones_form" model="ir.ui.view">
        <field name="name">abatar.direcciones.form</field>
        <field name="model">abatar.direcciones</field>
        <field name="arch" type="xml">
            <form string="Form de direcciones">
                <sheet>
                    <group>
                        <field name="cliente"/>
                        <field name="alias"/>
                        <field name="name"/>
                        <field name="piso"/>
                        <field name="dto"/>
                        <field name="localidad"/>
                        <field name="provincia"/>
                        <field name="obs"/>
                        <field name="contacto"/>
                        <field name="restricciones"/>
                        <field name="active"/>
                        <field name="admin" invisible="1"/>
                        <field name="forc_direc"  attrs="{'readonly': [('admin', '!=', True)]}" />
                    </group>
                    <group>
                        <field name="admin" invisible="1"/>
                        <field name="resumen_busqueda" invisible="1"/>

                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="direcciones_search" model="ir.ui.view">
        <field name="name">abatar.direcciones.search.view</field>
        <field name="model">abatar.direcciones</field>
        <field name="arch" type="xml">
            <search string="Buscar:">
                <field name="resumen_busqueda" />
                <separator/>

            </search>
        </field>
    </record>

    <record id="action_direcciones" model="ir.actions.act_window">
            <field name="name">Direcciones</field>
            <field name="res_model">abatar.direcciones</field>
            <field name="limit">200</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the first cash rounding</p>
            </field>
    </record>


</odoo>
