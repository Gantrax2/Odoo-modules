<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="caja_subtipo_tree" model="ir.ui.view">
        <field name="name">abatar.caja.subtipo.tree</field>
        <field name="model">abatar.caja.subtipo</field>
        <field name="arch" type="xml">
            <tree string="Lista de caja Subtipos">
                <field name="name"/>
                <field name="tipo"/>
            </tree>
        </field>
    </record>
    <record id="caja_subtipo_form" model="ir.ui.view">
        <field name="name">abatar.caja.subtipo.form</field>
        <field name="model">abatar.caja.subtipo</field>
        <field name="arch" type="xml">
            <form string="Lista de caja Subtipos">
                <field name="name"/>
                <field name="tipo"/>
            </form>
        </field>
    </record>

    <record id="action_caja_subtipo" model="ir.actions.act_window">
            <field name="name">Caja SubTipo</field>
            <field name="res_model">abatar.caja.subtipo</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create caja SubTipo</p>
            </field>
    </record>


</odoo>
