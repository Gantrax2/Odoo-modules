<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="clientes_tree" model="ir.ui.view">
        <field name="name">abatar.clientes.tree</field>
        <field name="model">abatar.clientes</field>
        <field name="arch" type="xml">
            <tree string="Lista de Clientes">
                <field name="name_seq"/>
                <field name="clientes_gral_id"/>
                <field name="sector"/>
                <field name="tel"/>
                <field name="cuit"/>
                <field name="sv_count0" readonly="1" invisible="1"/>
                <field name="sv_count" readonly="1"/>
                <field name="ordenes_r" readonly="1" invisible="1"/>
                <field name="ordenes_p" readonly="1"/>
                <field name="res_pendiente" readonly="1"/>
            </tree>
        </field>
    </record>

    <record id="clientes_form" model="ir.ui.view">
        <field name="name">abatar.clientes.form</field>
        <field name="model">abatar.clientes</field>
        <field name="arch" type="xml">
            <form string="Form de Clientes">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="ordenes_cl" class="oe_stat_button" type="object" icon="fa-calendar" attrs="{'invisible': [('sv_count0', 'in', (False, 0))]}">
                            <field name="sv_count" string="Ordenes" widget="statinfo"/> <span> Ordenes</span>
                        </button>
                        <button name="direcciones_cl" class="oe_stat_button" type="object" icon="fa-map-marker"  attrs="{'invisible': [('direcciones_r', 'in', (False, 0))]}">
                            <field name="direcciones_r" string="Direcciones" widget="statinfo"/>
                        </button>
                        <button name="resumenes_cl" class="oe_stat_button" type="object" icon="fa-map-marker" attrs="{'invisible': [('resumenes_r', 'in', (False, 0))]}">
                            <field name="resumenes_r" string="Resumenes" widget="statinfo"/>
                        </button>
                        <button name="pagos_cl" class="oe_stat_button" type="object" icon="fa-map-marker" attrs="{'invisible': [('pagos_r', 'in', (False, 0))]}">
                            <field name="pagos_r" string="Pagos" widget="statinfo"/>
                        </button>
                        <button name = "%(wsp_wizard)d" string = "WSP" type = "action" icon="fa-calendar" class="oe_stat_button"/>

                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <group>
                        <div class="oe_title">
                            <h1>
                                <field name="name_seq" readonly="1"/>
                            </h1>
                        </div>
                        <field name="clientes_gral_id"/>
                        <field name="sector"/>
                        <field name="active" invisible="1"/>
                        <field name="sv_count0" readonly="1" invisible="1"/>
                        <field name="sv_count" readonly="1"/>
                        <field name="name_gral" invisible="1" readonly="1"/>
                        <field name="name_gral2" invisible="1" readonly="1"/>
                        <field name="cuit"/>
                        <field name="image"/>
                        <field name="tel"/>
                        <field name="tel2"/>
                        <field name="email"/>
                        <field name="tarifas"/>
                    </group>
                    <group>
                        <field name="clientes_lines">
                            <tree editable="bottom">
                                <field name="name"/>
                                <field name="tel"/>
                                <field name="tel2"/>
                                <field name="email"/>
                                <field name="puesto"/>
                                <field name="clientes_id" invisible="1"/>
                            </tree>
                        </field>
                    </group>
                    <group>
                        <field name="admin" invisible="1"/>

                        <field name="resumen_busqueda" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="clientes_kanban" model="ir.ui.view">
        <field name="name">abatar.clientes.kanban</field>
        <field name="model">abatar.clientes</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="image"/>
                <field name="name_seq"/>
                <field name="name_gral" readonly="1"/>
                <field name="cuit"/>
                <field name="tel"/>
                <field name="ordenes_p" readonly="1"/>
                <field name="res_pendiente_str"/>
                <field name="res_pendiente" readonly="1" invisible="1"/>
                <field name="sv_count" readonly="1" invisible="1"/>
                <field name="sv_count0" readonly="1" invisible="1"/>
                <field name="ordenes_p2" readonly="1" invisible="1"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill o_res_partner_kanban">
                            <t t-if="record.image.raw_value">
                                <div class="o_kanban_image_fill_left d-none d-md-block" t-attf-style="background-image:url('#{kanban_image('abatar.clientes', 'image', record.id.raw_value)}')" />
                            </t>
                            <t t-else="">
                                <img class="o_kanban_image" alt="Avatar" t-att-src='_s + "/base/static/img/avatar.png"'/>
                            </t>
                            <div class="oe_kanban_details">
                                <strong><field name="clientes_gral_id" /></strong>
                                <strong><field name="sector" /></strong>
                                <div class="o_kanban_tags_section" />
                                <ul>
                                    <li><field name="tel" /></li>
                                    <li><field name="name_seq" /></li>
                                    <span>Resumenes pendientes: <strong><field name="res_pendiente_str"/></strong><br /></span>
                                    <li><field name="res_pendiente" invisible="1" readonly="1"/></li>
                                    <span> Cant Sv Pendientes de Fact: <strong><field name="ordenes_p"  readonly="1"/></strong><br /></span>
                                    <span> Cant Sv: <strong><field name="sv_count"  readonly="1"/></strong><br /></span>
                                    <span> Fact U$D: <strong><field name="sv_count_fact_dolar" readonly="1"/></strong><br /></span>
                                    <span> Fact/Sv U$D: <strong><field name="f_u_c_dolar" readonly="1"/></strong><br /></span>
                                    <span> Fact ult. Año U$D: <strong><field name="sv_count_fact_a_dolar" readonly="1"/></strong><br /></span>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <record id="board_graph_clientes" model="ir.ui.view">
        <field name="name">abatar.clientes.graph</field>
        <field name="model">abatar.clientes</field>
        <field name="arch" type="xml">
            <graph string="Clientes">
                <field name="clientes_gral_id"/>
                <field name="sector"/>
                <field name="res_pendiente_total"/>
                <field name="sv_count" invisible="1" readonly="1"/>
                <field name="sv_count_fact" invisible="1" readonly="1"/>
                <field name="sv_count_fact_a" invisible="1" readonly="1"/>
                <field name="f_u_c" invisible="1" readonly="1"/>
                <field name="sv_count_fact_dolar" invisible="1" readonly="1"/>
                <field name="sv_count_fact_a_dolar" invisible="1" readonly="1"/>
                <field name="f_u_c_dolar" invisible="1" readonly="1"/>
            </graph>
        </field>
    </record>

    <record id="view_clientes_search" model="ir.ui.view">
        <field name="name">abatar.clientes.search</field>
        <field name="model">abatar.clientes</field>
        <field name="arch" type="xml">
            <search string="Busqueda en clientes">
                <field name="resumen_busqueda" />
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Clientes" name="clientes_gral_id" context="{'group_by': 'clientes_gral_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_clientes" model="ir.actions.act_window">
            <field name="name">Clientes</field>
            <field name="res_model">abatar.clientes</field>
            <field name="limit">100</field>
            <field name="view_mode">kanban,tree,form,graph</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the first cash rounding</p>
            </field>
    </record>


    <record id="clientes_lines_tree" model="ir.ui.view">
        <field name="name">abatar.clientes.lines.tree</field>
        <field name="model">abatar.clientes.lines</field>
        <field name="arch" type="xml">
            <tree string="Lista de Contactos de Clientes">
                <field name="name"/>
                <field name="puesto"/>
                <field name="tel"/>
                <field name="tel2"/>
                <field name="email"/>
                <field name="clientes_id" />
            </tree>
        </field>
    </record>

    <record id="clientes_lines_form" model="ir.ui.view">
        <field name="name">abatar.clientes.lines.form</field>
        <field name="model">abatar.clientes.lines</field>
        <field name="arch" type="xml">
            <form string="Form de Clientes">
                <group>

                    <field name="name"/>
                    <field name="puesto"/>
                    <field name="tel"/>
                    <field name="tel2"/>
                    <field name="email"/>
                    <field name="clientes_id" />
                </group>
            </form>
        </field>
    </record>
    <record id="clientes_lines_graph" model="ir.ui.view">
        <field name="name">abatar.clientes.lines.graph</field>
        <field name="model">abatar.clientes.lines</field>
        <field name="arch" type="xml">
            <graph string="graph de Clientes">
                <field name="name"/>
                <field name="puesto"/>
                <field name="tel"/>
                <field name="tel2"/>
                <field name="email"/>
                <field name="clientes_id" />
            </graph>
        </field>
    </record>

    <record id="action_clientes_lines" model="ir.actions.act_window">
            <field name="name">Clientes</field>
            <field name="res_model">abatar.clientes.lines</field>
            <field name="limit">200</field>
            <field name="view_mode">tree,form,graph</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the first cash rounding</p>
            </field>
    </record>

</odoo>
