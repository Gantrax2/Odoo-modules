<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="cotizador_tree" model="ir.ui.view">
        <field name="name">abatar.cotizador.tree</field>
        <field name="model">abatar.cotizador</field>
        <field name="arch" type="xml">
            <tree string="Lista de cotizador">
                <field name="name_seq"/>
                <field name="fecha"/>
                <field name="tarifa"/>
                <field name="gastos_extra"/>
                <field name="resumen_busqueda" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="cotizador_form" model="ir.ui.view">
        <field name="name">abatar.cotizador.form</field>
        <field name="model">abatar.cotizador</field>
        <field name="arch" type="xml">
            <form string="Form de cotizador">
                <header>
                    <button name = "%(tarifa_cotiz_wizard)d" string = "Accion masiva" type = "action"/>
                </header>
                <sheet>

                <div class="oe_button_box" name="button_box">
                    <button name="action_view_crm"
                        type="object"
                        string="CRM"
                        class="oe_stat_button"
                        icon="fa-pencil-square-o"
                        attrs="{'invisible': [('crm', '=', False)]}">
                    </button>
                </div>

                    <div class="oe_title">
                        <h1>
                            <group>
                                <field name="tarifa" readonly="1"/>
                                <field name="crm" invisible="1"/>
                                <field name="kms" invisible="1"/>
                                <field name="AYD"/>
                            </group>

                        </h1>
                    </div>
                    <group>
                        <field name="fecha" autocomplete="off"/>
                        <field name="es_masiva" attrs="{'invisible': [('es_ivainc', '=', True)]}"/>
                        <field name="es_ivainc" attrs="{'invisible': [('es_masiva', '=', True)]}"/>
                        <field name="gastos_extra"/>
                        <field name="tarifa"/>
                        <field name="hay_categ"/>
                    </group>
                    <notebook>
                        <page string="Linea de Productos">
                            <button name="actualiza_precios"
                            type="object"
                            string="Actualiz.precios"
                            class="oe_stat_button"
                            icon="fa-pencil-square-o"/>
                            <field name="linea_personal">
                                <tree editable="bottom">
                                    <field name="desc"/>
                                    <field name="precio_forc"/>
                                    <field name="producto" domain="['|',('tipo', '=', id_unidad),('tipo', '=', id_operario)]"/>
                                    <field name="id_unidad" invisible="1"/>
                                    <field name="id_operario" invisible="1"/>
                                    <field name="cantidad"/>
                                    <field name="horas"/>
                                    <field name="kms"/>
                                    <field name="costo" readonly="1"/>
                                    <field name="costo_kms" readonly="1" />
                                    <field name="subt_costo" readonly="1"/>
                                    <field name="precio_f" />
                                    <field name="precio" readonly="1"/>
                                    <field name="precio_kms_f" />
                                    <field name="precio_kms" readonly="1" />
                                    <field name="subtotal" readonly="1"/>
                                    <field name="cotizador_id" invisible="1"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Linea de Embalaje">
                            <button name = "%(sets_wizard)d"
                                string = "SET MAT"
                                type = "action"
                                class="oe_stat_button"
                                icon="fa-pencil-square-o"/>
                            <button name="borra_embalaje"
                            type="object"
                            string="borra embalaje"
                            class="oe_stat_button"
                            icon="fa-pencil-square-o"/>
                            <field name="embalaje_lines">
                                <tree editable="bottom">
                                    <field name="embalaje_id" domain="[('tipo', '=', id_embalaje)]"/>
                                    <field name="id_embalaje" invisible="1"/>
                                    <field name="cantidad"/>
                                    <field name="precio" readonly="1"/>
                                    <field name="subtotal"/>
                                    <field name="costo" readonly="1"/>
                                    <field name="subt_costo"/>
                                    <field name="cotizador_id" invisible="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                    <group>
                        <group class="oe_subtotal_footer"   string="Costos">
                            <field name="costo_personal" readonly="1" widget='monetary' options="{'currency_field': 'currency_id'}"/>
                            <field name="costo_embalaje" readonly="1" widget='monetary' options="{'currency_field': 'currency_id'}"/>
                            <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                                <label for="costo_total"/>
                            </div>
                            <field name="costo_total" nolabel="1" class="oe_subtotal_footer_separator" widget='monetary' options="{'currency_field': 'currency_id'}"/>
                        </group>
                        <group class="oe_subtotal_footer oe_right" colspan="2" name="sale_total" string="Cobro">
                            <field name="subto_personal" widget='monetary' options="{'currency_field': 'currency_id'}"/>
                            <field name="subto_embalaje" widget='monetary' options="{'currency_field': 'currency_id'}"/>
                            <t t-if="es_ivainc==True"><span style="font-size: 10px">(IVA incluido)</span></t><field name="subto" widget='monetary' options="{'currency_field': 'currency_id'}"/>
                            <field name="aumento" attrs="{'invisible': [('aumento', 'in', (0, False))]}"/>
                            <field name="subto2" widget='monetary' options="{'currency_field': 'currency_id'}"  attrs="{'invisible': [('aumento', 'in', (0, False))]}"/>
                            <field name="iva" widget='monetary' options="{'currency_field': 'currency_id'}"  attrs="{'invisible': [('iva', 'in', (0, False))]}"/>
                            <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                                <t t-if="es_ivainc==True"><span>(Sin IVA)</span></t><label for="total"/>
                            </div>
                            <field name="total" nolabel="1" class="oe_subtotal_footer_separator" widget='monetary' options="{'currency_field': 'currency_id'}"/>
                        </group>
                    </group>
                    <group>

                        <field name="admin" invisible="1"/>
                        <field name="resumen_busqueda" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="cotizador_search" model="ir.ui.view">
        <field name="name">abatar.cotizador.search.view</field>
        <field name="model">abatar.cotizador</field>
        <field name="arch" type="xml">
            <search string="Buscar:">
                <field name="resumen_busqueda" />
                <separator/>

            </search>
        </field>
    </record>


    <record id="action_cotizador" model="ir.actions.act_window">
            <field name="name">Cotizador</field>
            <field name="res_model">abatar.cotizador</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the first cash rounding</p>
            </field>
    </record>


</odoo>
