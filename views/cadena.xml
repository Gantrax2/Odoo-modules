<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="cadena_tree" model="ir.ui.view">
        <field name="name">abatar.cadena.tree</field>
        <field name="model">abatar.cadena</field>
        <field name="arch" type="xml">
            <tree string="Lista de cadena">
                <field name="op_ud"/>
                <field name="tipo"/>
                <field name="fecha"/>
                <field name="hora_inicio"/>
                <field name="origen"/>
                <field name="destino"/>
                <field name="precio"/>
            </tree>
        </field>
    </record>

    <record id="cadena_form" model="ir.ui.view">
        <field name="name">abatar.cadena.form</field>
        <field name="model">abatar.cadena</field>
        <field name="arch" type="xml">
            <form string="Cadena">
                <header>
                    <button name = "%(wsp_wizard2)d" string = "Enviar Wapp a Operarios" type = "action" attrs="{'invisible': [('op_ud', '=', 'ud')]}"/>
                </header>
                <group string="Datos Envío">
                    <field name="op_ud"/>
                    <field name="tipo"/>
                    <field name="fecha"/>
                    <field name="hora_inicio"/>
                    <field name="origen"/>
                    <field name="contacto"/>
                    <field name="destino"/>
                    <field name="precio"/>
                </group>
            </form>
        </field>
    </record>

    <record id="action_cadena" model="ir.actions.act_window">
            <field name="name">cadena</field>
            <field name="res_model">abatar.cadena</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the first Wapp cadena</p>
            </field>
    </record>


</odoo>
