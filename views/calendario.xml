<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="calendario_tree" model="ir.ui.view">
        <field name="name">abatar.calendario.tree</field>
        <field name="model">abatar.calendario</field>
        <field name="arch" type="xml">
            <tree string="Lista de productos">
                <field name="name"/>
                <field name="minimo"/>
                <field name="precio"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="calendario_calendar" model="ir.ui.view">
        <field name="name">abatar.calendario.calendar</field>
        <field name="model">abatar.calendario</field>
        <field name="arch" type="xml">
            <calendar string="Calendar View" date_start="fecha_ejecucion" date_delay="duration" quick_add="False" color="accion">
                <field name="accion"/>
                <field name="name"/>
                <field name="name2"/>
                <field name="name3"/>
                <field name="name4"/>
                <field name="name5"/>
                <field name="name6"/>
                <field name="name7"/>
                <field name="active" invisible="1"/>
            </calendar>
        </field>
    </record>

    <record id="calendario_form" model="ir.ui.view">
        <field name="name">abatar.calendario.form</field>
        <field name="model">abatar.calendario</field>
        <field name="arch" type="xml">
            <form string="Form de Calendario">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_ordenes"
                            type="object"
                            string="Ordenes"
                            class="oe_stat_button"
                            icon="fa-pencil-square-o"
                            attrs="{'invisible': [('ordenes', '=', False)]}">
                        </button>
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>

                    </div>
                    <group>
                        <group>
                            <field name="name_seq" invisible="1"/>
                            <field name="name_oculto" invisible="1"/>
                            <field name="name"/>
                            <field name="precio"/>
                            <field name="accion"/>
                            <separator/>
                            <field name="ordenes"/>
                            <field name="deudas"/>
                            <field name="materiales"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="minimo"/>
                            <field name="fecha_ejecucion" autocomplete="off"/>
                            <field name="recontactar"/>
                            <label for="duration"/>
                                <div>
                                    <field name="duration" class="oe_inline" widget="float_time"/> Horas
                                </div>
                        </group>
                        <group>
                            <field name="total" attrs="{'readonly': ['|', ('minimo', '>', 0),('precio', '>', 0)]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ordenes">
                            <field name="calendario_lines">
                                <tree editable="bottom">
                                    <field name="crm"  domain="[('active' , '!=', False)]" />
                                    <field name="orden"  domain="[('active' , '!=', False)]" />
                                    <field name="pago"  domain="[('active' , '!=', False)]" />
                                    <field name="deuda"  domain="[('active' , '!=', False)]" />
                                    <field name="calendario_id" invisible="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                    <group>
                        <field name="desc"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="action_calendario" model="ir.actions.act_window">
        <field name="name">Calendario</field>
        <field name="res_model">abatar.calendario</field>
        <field name="view_mode">calendar,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Lista de Elementos de Calendario</p>
        </field>
    </record>


</odoo>
