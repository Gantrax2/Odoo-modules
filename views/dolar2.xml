    <record id="view_visor_search" model="ir.ui.view">
        <field name="name">abatar.visor.search</field>
        <field name="model">abatar.visor</field>
        <field name="arch" type="xml">
            <search string="Busqueda en Visor">
                <filter string="Nombre" name="NOMBRE_IMPOSIBLE" domain="[('NOMBRE_IMPOSIBLE' , 'ilike', 'self')]"/>
                <filter string="Nombre2" name="name2" domain="[('name2' , 'ilike', 'self')]"/>
                <filter string="Nombre1" name="name1" domain="[('name1' , 'ilike', 'self')]"/>
                <separator/>
                <filter string="Nombre" name="NOMBRE_IMPOSIBLE" context="{'group_by': 'NOMBRE_IMPOSIBLE'}"/>
                <filter string="Nombre1" name="name1" context="{'group_by': 'name1'}"/>
                <filter string="Nombre2" name="name2" context="{'group_by': 'name2'}"/>
                <filter string="X (num)" name="x_num" context="{'group_by': 'x_num'}"/>
                <filter string="X (text)" name="x_str" context="{'group_by': 'x_str'}"/>
                <filter string="X (fecha)" name="x_date" context="{'group_by': 'x_date'}"/>
                <filter string="X (V/F)" name="x_bool" context="{'group_by': 'x_bool'}"/>
            </search>
        </field>
    </record>


