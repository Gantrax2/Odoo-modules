<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="booleana_tree" model="ir.ui.view">
        <field name="name">abatar.booleana.tree</field>
        <field name="model">abatar.booleana</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="booleana_form" model="ir.ui.view">
        <field name="name">abatar.booleana.form</field>
        <field name="model">abatar.booleana</field>
        <field name="arch" type="xml">
            <form string="Form de productos">
                <group>
                    <field name="name"/>
                </group>
            </form>
        </field>
    </record>

    <record id="action_booleana" model="ir.actions.act_window">
            <field name="name">booleana</field>
            <field name="res_model">abatar.booleana</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create the first boolean item</p>
            </field>
    </record>


</odoo>
