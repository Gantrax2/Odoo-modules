<?xml version="1.0" encoding="utf-8"?>
<odoo>



    <record id="act_ordenes_finalizo" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">abatar.ordenes</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record model="ir.ui.view" id="board_form_view">
        <field name="name">My Dashboard</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="My Dashboard">
                <board style="2-1">
                    <column>
                        <action
                            string="Hola Paupu"
                            name="%(om_abatartrucks.board_graph_orden)"/>
                    </column>
                </board>
            </form>
        </field>
    </record>


    <record id="action_dash" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="usage">menu</field>
        <field name="view_id" ref="board_form_view"/>
    </record>


</odoo>
