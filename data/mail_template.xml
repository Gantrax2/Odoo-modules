<?xml version="1.0"?>
<odoo>

    <data noupdate="1">
        <!--Email template -->
        <record id="email_template_abatar" model="mail.template">
            <field name="name">Abatar: Send by email</field>
            <field name="model_id" ref="om_abatartrucks.model_abatar_crm"/>
            <field name="email_from">${object.user_id.email_formatted |safe}</field>
            <field name="email_to">${object.email}</field>
            <field name="subject">Invoice Prueba</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Estimado ${object.name}
    </p>
</div>
            </field>
        </record>
    </data>

    <data noupdate="1">
        <!--Email template -->
        <record id="email_template_abatar2" model="mail.template">
            <field name="name">Abatar: Send by email2</field>
            <field name="model_id" ref="om_abatartrucks.model_abatar_crm"/>
            <field name="email_from">${object.user_id.email_formatted |safe}</field>
            <field name="email_to">${object.email}</field>
            <field name="subject">Invoice Prueba</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Estimado ${object.name}
    </p>
</div>
            </field>
        </record>


        <template id="assets_backend" name="test_module assets" inherit_id="web.assets_backend">

            <xpath expr="." position="inside">

                <link rel="stylesheet" href="/om_abatartrucks/static/src/css/oe_new_custom_button2.css"/>

            </xpath>

        </template>
    </data>
</odoo>
