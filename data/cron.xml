<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="vencimiento_crm_cron" model="ir.cron">
            <field name="name">Venc CRM pedidos</field>
            <field name="model_id" ref="model_abatar_crm"/>
            <field name="type">ir.actions.server</field>
            <field name="state">code</field>
            <field name="code">model.vencimiento_state()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <!-- -1 para que nunca deje de hacerlo, si pones 10 ejecuta 10 veces. -->
        </record>
    </data>
</odoo>