<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <template id="report_clientes">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div style="padding-top: 100px">
                        <table width="100%" style="border: 3pt solid black; font-size: 25px">
                            <tr>
                                <td width="30%" style="border-right: 3pt solid black">
                                    <p>Hola Mundo</p>
                                </td>
                                <td>
                                    <span t-field="doc.name_seq"/>
                                </td>
                            </tr>
                        </table>
                    </div>

                </t>
            </t>
        </t>
    </template>

</odoo>