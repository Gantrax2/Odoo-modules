<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_euro2" model="report.paperformat">
        <field name="name">A4</field>
        <field name="default" eval="True" />
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">50</field>
        <field name="margin_bottom">7</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="True" />
        <field name="header_spacing">35</field>
        <field name="dpi">90</field>
    </record>



    <report
        id="report_orden_pdf"
        model="abatar.ordenes"
        string="Ordenes Internas en PDF"
        report_type="qweb-pdf"
        name="om_abatartrucks.report_ordenes"
        file="om_abatartrucks.report_ordenes"
        print_report_name="'%s' % (object.name_seq)"/>



    <report
        id="report_orden_clientes"
        model="abatar.ordenes"
        string="Ordenes Clientes en PDF"
        report_type="qweb-pdf"
        name="om_abatartrucks.report_ordenes_clientes"
        file="om_abatartrucks.report_ordenes_clientes"
        print_report_name="'%s' % (object.name_seq)"/>



    <report
        id="report_ordenes_proveedores"
        model="abatar.ordenes"
        string="Ordenes Proveedores en PDF"
        report_type="qweb-pdf"
        name="om_abatartrucks.report_ordenes_proveedores"
        file="om_abatartrucks.report_ordenes_proveedores"
        print_report_name="'%s' % (object.name_seq)"/>


    <report
        id="report_crm_pdf"
        model="abatar.crm"
        string="CRM en PDF"
        report_type="qweb-pdf"
        name="om_abatartrucks.report_crm"
        file="om_abatartrucks.report_crm"
        print_report_name="'%s' % (object.pedide)"/>

    <report
        id="report_crm2_pdf"
        model="abatar.crm"
        string="CRM PRESUP. en PDF"
        report_type="qweb-pdf"
        name="om_abatartrucks.report_crm2"
        file="om_abatartrucks.report_crm2"
        print_report_name="'%s' % (object.pedide)"/>

    <report
        id="report_resumenes_pdf"
        model="abatar.resumenes"
        string="RESUMEN en PDF"
        report_type="qweb-pdf"
        name="om_abatartrucks.report_resumenes"
        file="om_abatartrucks.report_resumenes"
        print_report_name="'RESUMEN %s - %s' % (object.name_seq,object.clientes_id.name_gral2)"
        paperformat ="om_abatartrucks.paperformat_euro2"/>
    <report
        id="report_caja_pdf"
        model="abatar.caja"
        string="Caja en PDF"
        report_type="qweb-pdf"
        name="om_abatartrucks.report_caja"
        file="om_abatartrucks.report_caja"
        print_report_name="'CAJA - %s' % (object.fecha_de_caja)"/>

    <report
        id="report_clientes_pdf"
        model="abatar.clientes"
        string="Clientes en PDF"
        report_type="qweb-pdf"
        name="om_abatartrucks.report_clientes"
        file="om_abatartrucks.report_clientes"
        print_report_name="'CLIENTES - %s' % (object.name)"/>


</odoo>
